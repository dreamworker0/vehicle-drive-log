{
    "name": "functions",
    "description": "Cloud Functions for 차량운행일지",
    "scripts": {
        "build": "tsc",
        "gcp-build": "",
        "build:watch": "tsc --watch",
        "test": "jest --verbose --testPathIgnorePatterns=emulator",
        "test:emulator": "jest --verbose --runInBand --testPathPattern=\"emulator\\.test\"",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "22"
    },
    "main": "lib/functions/src/index.js",
    "dependencies": {
        "@emailjs/nodejs": "^5.0.2",
        "@google/genai": "^1.0.0",
        "@sentry/node": "^10.45.0",
        "firebase-admin": "^13.0.0",
        "firebase-functions": "^6.0.0",
        "googleapis": "^144.0.0",
        "nodemailer": "^9.0.1"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^22.0.0",
        "@types/nodemailer": "^7.0.12",
        "firebase-functions-test": "^3.1.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.0",
        "typescript": "^5.7.0"
    },
    "jest": {
        "testEnvironment": "node",
        "coverageProvider": "v8",
        "roots": [
            "<rootDir>/src"
        ],
        "transform": {
            "^.+\\.tsx?$": [
                "ts-jest",
                {
                    "diagnostics": false
                }
            ]
        }
    },
    "private": true,
    "overrides": {
        "minimatch": ">=9.0.5",
        "uuid": "^11.1.1",
        "js-yaml": "^4.2.0"
    }
}
