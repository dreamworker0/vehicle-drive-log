{
  "permissions": {
    "comment": "읽기전용·개발용 상시 명령의 공용 allowlist. 개인 전용 추가는 settings.local.json에.",
    "allow": [
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npm run *)",
      "Bash(npx vitest *)",
      "Bash(npx jest *)",
      "Bash(gh pr view *)",
      "PowerShell(gh pr view *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/guard-firebase-deploy.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/lint-changed.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/hooks/sync-agent-bridge.mjs"
          }
        ]
      }
    ]
  }
}
