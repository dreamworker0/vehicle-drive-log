rules_version = '2';

// === 헬퍼 함수 (Custom Claims 기반 — Firestore get() 호출 최소화) ===
function isSuperAdmin() {
  return request.auth != null && request.auth.token.role == 'superAdmin';
}

function isOrgMember(orgId) {
  return request.auth != null && request.auth.token.orgId == orgId;
}

service firebase.storage {
  match /b/{bucket}/o {
    // 기관 고유번호증 사본 업로드
    // 신청자는 아직 Custom Claims가 없으므로 Firestore fallback 유지
    match /organizations/{orgId}/{allPaths=**} {
      allow read: if isOrgMember(orgId)
                  || isSuperAdmin()
                  || (request.auth != null
                      && firestore.get(/databases/(default)/documents/organizations/$(orgId)).data.applicantUid == request.auth.uid);
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf')
                   && (isOrgMember(orgId)
                       || firestore.get(/databases/(default)/documents/organizations/$(orgId)).data.applicantUid == request.auth.uid);
    }

    // OCR 인식 오류 신고 이미지 업로드 (본인 폴더만)
    match /feedbacks/ocr-report/{userId}/{fileName} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 일반 피드백 이미지 업로드 (본인 폴더만)
    match /feedbacks/{userId}/{fileName} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
