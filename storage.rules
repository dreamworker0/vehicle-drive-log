rules_version = '2';

// === 헬퍼 함수 (Custom Claims 기반 — Firestore get() 호출 최소화) ===
function isSuperAdmin() {
  return request.auth != null && request.auth.token.role == 'superAdmin';
}

service firebase.storage {
  match /b/{bucket}/o {
    // 기관 고유번호증 사본(정부 발급 PII) — 업로드는 submitOrgApplication 함수(Admin SDK)가 수행하므로
    // 클라이언트 쓰기는 차단하고, 경로도 단일 파일 수준으로 제한 (중첩 경로 업로드 방지).
    // 읽기는 superAdmin 전용: 앱은 superAdmin 콜러블(getOrgDocumentUrl)이 발급하는 단기 서명 URL로만
    // 표시하며, 어떤 클라이언트도 이 경로를 직접 읽지 않는다. org 멤버 직접 읽기 권한은 불필요한
    // PII 노출 표면이라 제거한다. (2026-07-18 보안 재점검 B)
    match /organizations/{orgId}/{fileName} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // OCR 인식 오류 신고 이미지 업로드 (본인 폴더만)
    match /feedbacks/ocr-report/{userId}/{fileName} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 일반 피드백 이미지 업로드 (본인 폴더만)
    match /feedbacks/{userId}/{fileName} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
