rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {



    // === 헬퍼 함수 (Custom Claims 기반 — get() 호출 없이 빠른 검증) ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.role == 'superAdmin';
    }

    function isOrgMember(orgId) {
      return isSignedIn()
        && request.auth.token.orgId == orgId;
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId)
        && request.auth.token.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userOrgId() {
      return request.auth.token.orgId;
    }

    function belongsToMyOrg() {
      return isSignedIn() && resource.data.organizationId == userOrgId();
    }

    function newBelongsToMyOrg() {
      return isSignedIn() && request.resource.data.organizationId == userOrgId();
    }

    // === 사용자 ===
    match /users/{userId} {
      // 자기 자신 + superAdmin + 같은 기관 멤버만 읽기 가능
      allow read: if isOwner(userId)
                  || isSuperAdmin()
                  || (isSignedIn() && resource != null && resource.data.organizationId == userOrgId());
      allow create: if isOwner(userId)
                    && request.auth.token.firebase.sign_in_provider != 'anonymous'
                    && request.resource.data.keys().hasAll(['email'])
                    && request.resource.data.email is string
                    && !request.resource.data.keys().hasAny(['role', 'organizationId']);
      allow update: if (isOwner(userId)
                        && (
                            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'organizationId', 'status', 'disabledAt'])
                            || (
                                // 사용자가 스스로 기관을 탈퇴/초기화하여 '다른 기관으로 가입'하는 행위 허용
                                request.resource.data.organizationId == null
                                && request.resource.data.role == 'employee'
                                && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'disabledAt'])
                            )
                        ))
                    || isSuperAdmin()
                    // orgAdmin은 소속 기관 사용자만 수정 가능하되, superAdmin 역할 부여 불가.
                    // organizationId는 불변으로 강제한다 — admin이 자기/타인 문서의 org를 바꿔
                    // 타 기관 admin 클레임을 획득하는 교차 테넌트 권한상승을 차단(2026-07-04 감사 N1).
                    || (isOrgAdmin(resource.data.organizationId)
                        && request.resource.data.role != 'superAdmin'
                        && request.resource.data.organizationId == resource.data.organizationId);
      allow delete: if isSuperAdmin();

      // 비밀 사용자 데이터 (Google OAuth access/refresh 토큰 등) — Cloud Functions(Admin SDK) 전용.
      // 과거 users 문서에 googleOauth를 저장해 같은 기관 멤버 누구나 리프레시 토큰을 읽어
      // 계정을 임퍼소네이션할 수 있었음 (2026-07-10 감사 #4).
      match /private/{docId} {
        allow read, write: if false;
      }
    }

    // === 기관 ===
    match /organizations/{orgId} {
      // 소속 멤버, 신청자 본인, superAdmin만 읽기 가능 (초대 코드 검증은 Cloud Function에서 처리)
      allow read: if isSuperAdmin()
                  || isOrgMember(orgId)
                  || (isSignedIn() && resource.data.applicantUid == request.auth.uid);
      // 기관 생성은 서버(submitOrgApplication, Admin SDK) 또는 superAdmin 전용.
      // 과거 클라이언트 create는 status:'approved'·inviteCode를 임의 지정해 AI 검증·
      // superAdmin 승인 절차를 통째로 우회할 수 있었음 (2026-07-10 감사 #2).
      allow create: if isSuperAdmin();
      allow update: if isOrgAdmin(orgId) || isSuperAdmin()
                    || (isSignedIn() && resource.data.status == 'pending' && resource.data.applicantUid == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'role']));
      allow delete: if isSuperAdmin();

      // 커스텀 휴일 (서브컬렉션)
      match /customHolidays/{holidayId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId) || isSuperAdmin();
      }

      // 직원 사전 등록 (서브컬렉션)
      match /preRegistered/{preRegId} {
        allow read: if isOrgMember(orgId) || isSuperAdmin();
        allow write: if isOrgAdmin(orgId) || isSuperAdmin();
      }

      // 집계 통계 (서브컬렉션 — Cloud Functions에서 생성/갱신)
      match /stats/{statId} {
        allow read: if isOrgMember(orgId) || isSuperAdmin();
        allow write: if false; // Cloud Functions(admin SDK)에서만 쓰기
      }
    }

    // === 차량 ===
    match /vehicles/{vehicleId} {
      allow read: if belongsToMyOrg() || isSuperAdmin();
      allow create: if ((newBelongsToMyOrg() && isOrgAdmin(request.resource.data.organizationId)) || isSuperAdmin())
                    && (!request.resource.data.keys().hasAny(['currentKm']) || request.resource.data.currentKm >= 0);
      allow update: if isSuperAdmin()
                    // organizationId는 불변 — admin이 차량을 타 기관으로 이전해 통계·주행거리를
                    // 오염시키는 교차 테넌트 무결성 침해 차단 (2026-07-10 감사 #6).
                    || (isOrgAdmin(resource.data.organizationId)
                        && request.resource.data.organizationId == resource.data.organizationId
                        && (!request.resource.data.keys().hasAny(['currentKm']) || request.resource.data.currentKm >= 0))
                    // 소속 기관 멤버가 운행일지 저장 시 currentKm만 갱신 가능 (감소 방지)
                    || (isOrgMember(resource.data.organizationId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentKm'])
                        && request.resource.data.currentKm >= resource.data.currentKm
                        && request.resource.data.currentKm >= 0);
      allow delete: if isOrgAdmin(resource.data.organizationId) || isSuperAdmin();
    }

    // === 하이패스 카드 ===
    match /hipassCards/{cardId} {
      allow read: if belongsToMyOrg() || isSuperAdmin();
      allow create: if (newBelongsToMyOrg() && isOrgAdmin(request.resource.data.organizationId))
                    || isSuperAdmin();
      allow update: if isSuperAdmin()
                    || (isOrgAdmin(resource.data.organizationId)
                        && request.resource.data.organizationId == resource.data.organizationId)
                    // 소속 기관 멤버가 충전 시 balance만 갱신 가능 (음수 방지)
                    || (isOrgMember(resource.data.organizationId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'updatedAt'])
                        && request.resource.data.balance >= 0);
      allow delete: if isOrgAdmin(resource.data.organizationId) || isSuperAdmin();
    }

    // === 운행일지 ===
    match /driveLogs/{logId} {
      allow read: if belongsToMyOrg() || isSuperAdmin();
      // 작성자(createdByUid)만 생성 가능. driverUid(대표 운전자)는 작성자가 타인으로 지정할 수 있으므로
      // 소유자 판정 기준을 createdByUid로 분리 (2026-07-17 운전자 지정 기능).
      // 슈퍼관리자는 지원·테스트 목적으로 어느 기관에서든 생성 가능(작성자 위조는 여전히 금지).
      allow create: if (isSuperAdmin() || newBelongsToMyOrg())
                    && request.resource.data.keys().hasAll(['organizationId', 'vehicleId', 'driverUid', 'createdByUid'])
                    && request.resource.data.createdByUid == request.auth.uid
                    && (!request.resource.data.keys().hasAny(['startKm']) || request.resource.data.startKm >= 0)
                    && (!request.resource.data.keys().hasAny(['endKm']) || request.resource.data.endKm >= 0);
      allow update: if (isSuperAdmin()
                    || (belongsToMyOrg() && (
                        // 소유자(작성자)는 driverUid(대표 운전자) 포함 정보 수정 가능. createdByUid는 폴백으로 구 데이터 호환.
                        // organizationId·vehicleId·createdByUid는 불변.
                        ((resource.data.createdByUid == request.auth.uid
                            || (!('createdByUid' in resource.data) && resource.data.driverUid == request.auth.uid))
                            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['organizationId', 'vehicleId', 'createdByUid']))
                        // organizationId 불변 — admin의 타 기관 이전 차단 (2026-07-10 감사 #6)
                        || (isOrgAdmin(resource.data.organizationId) && request.resource.data.organizationId == resource.data.organizationId)
                    )))
                    && (!request.resource.data.keys().hasAny(['startKm']) || request.resource.data.startKm >= 0)
                    && (!request.resource.data.keys().hasAny(['endKm']) || request.resource.data.endKm >= 0);
      allow delete: if isOrgAdmin(resource.data.organizationId) || isSuperAdmin();
    }

    // === 예약 ===
    match /reservations/{reservationId} {
      allow read: if belongsToMyOrg() || isSuperAdmin();
      // 예약 생성은 createReservationSafe(콜러블, Admin SDK) 전용.
      // 클라이언트 직접 create는 allowedUserIds(차량 사용 제한)·시간 중복·승인 필요 여부
      // 검증을 우회할 수 있었음 (2026-07-10 감사 #5).
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin()
                    || (belongsToMyOrg() && (
                        // 소유자는 취소·운행 종료·정보 수정만 가능. pending→reserved 자가 승인은 차단
                        // (requireReservationApproval 우회 방지 — 승인은 admin만).
                        (resource.data.reservedByUid == request.auth.uid
                            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['organizationId', 'reservedByUid'])
                            && !(resource.data.status == 'pending' && request.resource.data.status == 'reserved'))
                        // organizationId 불변 — admin의 타 기관 이전 차단 (2026-07-10 감사 #6)
                        || (isOrgAdmin(resource.data.organizationId) && request.resource.data.organizationId == resource.data.organizationId)
                    ));
      allow delete: if isSuperAdmin();
    }

    // === 알림 ===
    match /notifications/{notificationId} {
      allow read: if resource.data.targetUid == request.auth.uid || isSuperAdmin();
      // 클라이언트 생성은 superAdmin 전용 (승인/반려 알림 화면). 나머지 알림은 전부
      // Cloud Functions(admin SDK, Rules 우회)가 생성한다.
      // 과거 isSignedIn() 분기는 targetUid 소속 검증이 없어 임의 사용자가 타 기관
      // UID로 알림 텍스트를 주입할 수 있었음 (2026-07-03 감사 발견으로 제거).
      allow create: if isSuperAdmin();
      allow update: if resource.data.targetUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'updatedAt']);
      allow delete: if resource.data.targetUid == request.auth.uid || isSuperAdmin();
    }

    // === 즐겨찾기 ===
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // === 주유 기록 ===
    match /fuelLogs/{logId} {
      allow read: if belongsToMyOrg() || isSuperAdmin();
      allow create: if newBelongsToMyOrg()
                    && request.resource.data.keys().hasAll(['organizationId', 'vehicleId', 'driverUid'])
                    && request.resource.data.driverUid == request.auth.uid;
      allow update: if isSuperAdmin()
                    || (belongsToMyOrg() && (
                        (resource.data.driverUid == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['organizationId', 'vehicleId', 'driverUid']))
                        // organizationId 불변 — admin의 타 기관 이전 차단 (2026-07-10 감사 #6)
                        || (isOrgAdmin(resource.data.organizationId) && request.resource.data.organizationId == resource.data.organizationId)
                    ));
      allow delete: if (belongsToMyOrg()
                    && (resource.data.driverUid == request.auth.uid
                        || isOrgAdmin(resource.data.organizationId)))
                    || isSuperAdmin();
    }

    // === 하이패스 충전 기록 ===
    match /hipassCharges/{chargeId} {
      allow read: if belongsToMyOrg() || isSuperAdmin();
      allow create: if newBelongsToMyOrg()
                    && request.resource.data.keys().hasAll(['organizationId', 'cardId', 'chargerUid'])
                    && request.resource.data.chargerUid == request.auth.uid;
      allow update: if isSuperAdmin()
                    || (belongsToMyOrg() && (
                        (resource.data.chargerUid == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['organizationId', 'cardId', 'chargerUid']))
                        // organizationId 불변 — admin의 타 기관 이전 차단 (2026-07-10 감사 #6)
                        || (isOrgAdmin(resource.data.organizationId) && request.resource.data.organizationId == resource.data.organizationId)
                    ));
      allow delete: if (belongsToMyOrg()
                    && (resource.data.chargerUid == request.auth.uid
                        || isOrgAdmin(resource.data.organizationId)))
                    || isSuperAdmin();
    }

    // === 정비 기록 ===
    match /maintenanceRecords/{recordId} {
      allow read: if belongsToMyOrg() || isSuperAdmin();
      allow create: if isSuperAdmin()
                    || (newBelongsToMyOrg() && isOrgAdmin(request.resource.data.organizationId))
                    // 직원 본인 작성 — 차량 차단(blockVehicle) 권한은 관리자 전용이므로 false만 허용
                    || (newBelongsToMyOrg()
                        && request.resource.data.keys().hasAll(['organizationId', 'vehicleId', 'createdByUid'])
                        && request.resource.data.createdByUid == request.auth.uid
                        && request.resource.data.blockVehicle == false);
      allow update: if isSuperAdmin()
                    // organizationId 불변 — admin의 타 기관 이전 차단 (2026-07-10 감사 #6)
                    || (isOrgAdmin(resource.data.organizationId)
                        && request.resource.data.organizationId == resource.data.organizationId)
                    // 직원 본인 작성 건만 수정 — 소유자·기관·차량 불변, 차량 차단 불가
                    || (belongsToMyOrg()
                        && resource.data.createdByUid == request.auth.uid
                        && request.resource.data.createdByUid == resource.data.createdByUid
                        && request.resource.data.organizationId == resource.data.organizationId
                        && request.resource.data.vehicleId == resource.data.vehicleId
                        && request.resource.data.blockVehicle == false);
      allow delete: if isOrgAdmin(resource.data.organizationId) || isSuperAdmin()
                    // 직원 본인 작성 건 삭제
                    || (belongsToMyOrg() && resource.data.createdByUid == request.auth.uid);
    }

    // === 피드백 ===
    match /feedbacks/{feedbackId} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // === 기관 신청 ===
    match /orgApplications/{appId} {
      allow read: if isSuperAdmin()
                  || (isSignedIn() && resource.data.applicantEmail == request.auth.token.email);
      allow create: if isSignedIn()
                    && request.resource.data.applicantEmail == request.auth.token.email;
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // === 통계 컬렉션 ===
    match /orgStats/{orgId} {
      match /monthly/{docId} {
        allow read: if isOrgMember(orgId) || isSuperAdmin();
        allow write: if false; // Cloud Functions에서만 쓰기
      }
    }

    // === 시스템 ===
    match /system/{document} {
      allow read: if isSuperAdmin() || (document == 'holidays' && isSignedIn());
      allow write: if false; // Cloud Functions에서만 쓰기
    }

    // === 메신저 어시스턴트 (Slack 등) — 서버 전용, 클라이언트 접근 전면 차단 ===
    match /integrations/{docId} {
      allow read, write: if false; // 워크스페이스↔기관 매핑 (콘솔/Functions에서만 관리)
    }
    match /slackUsers/{docId} {
      allow read, write: if false; // Slack 사용자↔앱 계정 매핑 캐시
    }
    match /slackTasks/{docId} {
      allow read, write: if false; // 수신 이벤트 task 큐 (TTL 자동 정리)
    }
    match /slackConfirmations/{docId} {
      allow read, write: if false; // 예약 확인 대기 문서 (TTL 자동 정리)
    }
    match /assistantConversations/{docId} {
      allow read, write: if false; // 멀티턴 대화 상태(진행 중 예약 슬롯) (TTL 자동 정리)
    }
  }
}
