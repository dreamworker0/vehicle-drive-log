{
  "name": "vehicle-drive-log",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "tsx scripts/generate-sw-config.ts",
    "build": "vite build",
    "postbuild": "tsx scripts/check-bundle-size.ts && tsx scripts/generate-seo.ts",
    "screenshots": "tsx scripts/generate-screenshots.ts",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --exclude='' tests/firestore-rules.test.ts\"",
    "audit": "tsx scripts/security-audit.ts",
    "sync:agents": "tsx scripts/sync-claude-agents.ts",
    "health": "tsx scripts/check-functions-health.ts",
    "test:e2e": "playwright test",
    "test:e2e:emulator": "firebase emulators:exec --only auth,firestore \"playwright test -c playwright.emulator.config.ts\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/react": "^10.57.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/leaflet": "^1.9.21",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.4.0",
    "firebase": "^12.14.0",
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.1",
    "web-vitals": "^5.3.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "firebase-admin": "^13.8.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "minimatch": ">=9.0.5",
    "uuid": "^11.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --no-warn-ignored --max-warnings=0",
      "vitest related --run"
    ]
  }
}
